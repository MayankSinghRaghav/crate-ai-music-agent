# ─────────────────────────────────────────────────────────────────────────────
# Crate — environment. Copy to `.env`. EVERYTHING here is OPTIONAL for local dev:
# with no keys and no Postgres, Crate runs fully in deterministic stub mode.
# ─────────────────────────────────────────────────────────────────────────────

# --- AI providers (leave blank to use offline stubs) ---
# Generative text (bridges, taste summaries, review tagging). Pick ONE:
#   Groq = free tier, simplest key (recommended). Key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#   Gemini = free tier (if available in your region). Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#   Claude (paid) — also supported.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Force a backend: auto (default) | groq | gemini | claude | stub
LLM_PROVIDER=auto

# Embeddings stay FREE via the built-in stub unless you set this (paid OpenAI):
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-large

# --- Data layer ---
# DB_BACKEND:     sqlite (default, zero-setup)  | postgres (use docker-compose)
# VECTOR_BACKEND: local  (default, in-process)  | pgvector | pinecone
DB_BACKEND=sqlite
VECTOR_BACKEND=local
# Only used when DB_BACKEND=postgres (matches docker-compose.yml):
DATABASE_URL=postgresql://crate:crate@localhost:5432/crate
# Only used when DB_BACKEND=sqlite (defaults to services/api/crate.db):
# CRATE_DB_PATH=

# Only used when VECTOR_BACKEND=pinecone:
PINECONE_API_KEY=

# --- Hosting (production) ---
# Origin(s) the deployed web app is served from, comma-separated, so the API's
# CORS lets the browser through. Localhost is always allowed for local dev.
#   e.g. ALLOWED_ORIGINS=https://crate.vercel.app
ALLOWED_ORIGINS=
# Requests per minute per client IP (0 disables). Default 60.
RATE_LIMIT_PER_MIN=60
# DEMO_MODE=false hides the /dev/* endpoints (seed/reset/simulate) entirely.

# --- Adoption (North Star) thresholds ---
DEMO_MODE=true
ADOPT_DAYS=4
ADOPT_WEEKS=3

# --- Review Discovery Engine (ingest/) — all optional ---
# Without any of these, the pipeline runs offline on bundled, PII-free sample
# fixtures for every source. Each source goes live independently when its key/flag
# is set; anything unset falls back to fixtures.
DEDUPE_THRESHOLD=0.92

# Reddit — official API via PRAW. https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=crate-discovery-engine/0.1

# Keyless sources (Apple RSS + google-play-scraper + Spotify Community API) — opt
# in by listing them here, comma-separated, e.g.
#   LIVE_SOURCES=app_store,play_store,spotify_community
LIVE_SOURCES=
APP_STORE_APP_ID=324684580
APP_STORE_COUNTRY=us
PLAY_STORE_APP_ID=com.spotify.music
PLAY_STORE_LANG=en
SPOTIFY_COMMUNITY_QUERY=discover recommendation

# X (Twitter) API v2 — bearer token enables live mode. https://developer.x.com
X_BEARER_TOKEN=
X_QUERY=(spotify discovery OR "discover weekly") lang:en -is:retweet

# YouTube Data API v3 — key + comma-separated video ids to pull comments from.
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_IDS=

# Product Hunt GraphQL API v2 — developer token.
# https://www.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=
PRODUCT_HUNT_SLUG=spotify
