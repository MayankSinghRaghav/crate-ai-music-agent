# Build context is the repo root (see services/api/Dockerfile). Keep the image lean.
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
**/.pytest_cache/
**/*.egg-info/

# never ship local DBs or secrets
**/*.db
**/.env
**/.env.local

# node / next (the API image doesn't need the web app)
apps/web/node_modules/
apps/web/.next/
**/node_modules/
**/.next/

# ingest engine's own venv + outputs
ingest/.venv/
ingest/out/

# git / editor / OS
.git/
.github/
**/.DS_Store
**/Thumbs.db
*.pptx
